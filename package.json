{
  "name": "bakery-dain",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run worker:check && vite build",
    "preview": "vite preview",
    "db:migrate:local": "wrangler d1 execute bakery-dain-db --local --file worker/db/migrations/0001_initial_schema.sql",
    "db:migrate:remote": "wrangler d1 execute bakery-dain-db --remote --file worker/db/migrations/0001_initial_schema.sql",
    "db:seed:local": "wrangler d1 execute bakery-dain-db --local --file worker/db/seeds/0001_seed_mock_data.sql",
    "db:seed:remote": "wrangler d1 execute bakery-dain-db --remote --file worker/db/seeds/0001_seed_mock_data.sql",
    "worker:check": "tsc -p worker/tsconfig.json",
    "worker:deploy": "wrangler deploy",
    "worker:dev": "wrangler dev"
  },
  "dependencies": {
    "hono": "^4.12.28",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "wrangler": "^4.107.0"
  }
}
